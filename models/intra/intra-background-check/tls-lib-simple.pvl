(**********************************************************************)
(* Type Declarations *)
(**********************************************************************)
type sym_enc_key.   (*Symmetric encrption key*)
type sym_cipher.  (*Symmetric cipher/encrypted data*)

(**********************************************************************)
(* Declarations of functions, equational theories and rewrite rules *)
(**********************************************************************)
fun sym_enc(sym_enc_key,bitstring): sym_cipher.

(*Good practice to add function declaration for destructors also*)
(* Rewrite rule *)
fun sym_dec(sym_enc_key,sym_cipher): bitstring
reduc forall k:sym_enc_key, m:bitstring; 
  sym_dec(k,sym_enc(k,m)) = m.

fun b2s(bitstring): sym_enc_key [data].

free mesg:bitstring [private].

(********************************************************)
(* HPKE Object-Level Encryption for Evidence *)
(********************************************************)
(* hpke_enc(pubkey, plaintext, aad) *)
fun hpke_enc(pubkey, bitstring, bitstring): bitstring.

(* Reduction rule: decryption only succeeds with the matching private key and identical AAD *)
reduc forall k: privkey, m: bitstring, aad: bitstring;
      hpke_dec(k, hpke_enc(pk(k), m, aad), aad) = m.

(**********************************************************************)
(* Sanity Checks (Reachability props): should all be false (confirms event is reachable) *)
(**********************************************************************)

(* should be false (confirms event is reachable) *)
query ev:bitstring;
      event(Accepted(ev)).

(* should be false (confirms event is reachable) *)
query log:bitstring;
      event(Appraised(log)).

(* should be false (confirms event is reachable) *)
query ev:bitstring;
      event(ClientConn(ev)).

(* should be false (confirms event is reachable) *)
query cr:random, sr:random, psk:preSharedKey, pubCSK:pubkey,
      offer:params, mode:params,
      kc:ae_key, ks:ae_key, ems:bitstring, rms:bitstring;
      event(ClientFinished(pubCSK,psk,cr,sr,offer,mode,kc,ks,ems,rms)).

(* should be false (confirms event is reachable) *)
query cr:random, sr:random, psk:preSharedKey, VM_S:identity, ID_C:identity, pubLTK:pubkey,
      offer:params, mode:params,
      kc:ae_key, ks:ae_key, ems:bitstring, rms:bitstring;
      event(ClientFinRecentAgr(VM_S,ID_C,pubLTK,psk,offer,mode,kc,ks,ems,rms,cr,sr)).

(* should be false (confirms event is reachable) *)
query cr:random, sr:random, psk:preSharedKey, pubLTK:pubkey,
      offer:params, mode:params,
      kc:ae_key, ks:ae_key, ems:bitstring, rms:bitstring;
      event(ServerFinished(cr,sr,psk,pubLTK,offer,mode,kc,ks,ems,rms)).

(* should be false (confirms both events are reachable with a shared kem_ss) *)
query idS:identity, idXS:identity, kem_ss:bitstring;
      event(ServerID(idS,kem_ss)) &&
      event(ClientID(idXS,kem_ss)).

(* should be false (confirms event is reachable) *)
query rdata:bitstring;
      event(AcceptedRdata(rdata)).

(* should be false (confirms events are reachable) *)
query pubCSK:pubkey, dev_state:bitstring, quote:bitstring,
      cr:random, sr:random, cr':random, sr':random,
      VM_S:identity, pubLTK:pubkey, pubAEK:pubkey, pubEKK:pubkey,
      psk:preSharedKey, ct:kem_ct,
      offer:params, mode:params,
      kc:ae_key, ks:ae_key, ems:bitstring, rms:bitstring;
  event(ClientFinished(pubCSK,psk,cr,sr,offer,mode,kc,ks,ems,rms)) &&
  event(ServerFinished(cr,sr,psk,pubLTK,offer,mode,kc,ks,ems,rms)) ==>
  event(ServerChoosesKEX(cr,sr,MLKEM_13_S(WeakKEM,ct))) ||
  event(ServerChoosesHash(cr',sr',WeakHash)) ||
  event(LeakedAEK(pubAEK)) ||
  event(LeakedCSK(pubCSK)) ||
  event(LeakedLTK(pubLTK)) ||
  event(LeakedEKK(pubEKK))
.

(* should be false (confirms events are reachable) *)
query pubCSK:pubkey, dev_state:bitstring, quote:bitstring,
      cr:random, sr:random, cr':random, sr':random,
      VM_S:identity, pubLTK:pubkey, pubAEK:pubkey, pubEKK:pubkey,
      psk:preSharedKey, ct:kem_ct,
      offer:params, mode:params,
      kc:ae_key, ks:ae_key, ems:bitstring, rms:bitstring;
  event(ClientComp(VM_S,pubLTK,psk,offer,mode,kc,ks,ems,rms,cr,sr,pubCSK,dev_state)) &&
  event(ServerComp(VM_S,pubLTK,psk,offer,mode,kc,ks,ems,cr,sr,pubCSK,dev_state)) ==>
  event(ServerChoosesKEX(cr,sr,MLKEM_13_S(WeakKEM,ct))) ||
  event(ServerChoosesHash(cr',sr',WeakHash)) ||
  event(LeakedAEK(pubAEK)) ||
  event(LeakedCSK(pubCSK)) ||
  event(LeakedLTK(pubLTK)) ||
  event(LeakedEKK(pubEKK))
.

(**********************************************************************)
(* Relay attacks queries *)
(**********************************************************************)

(* Reachability *)
query ev:bitstring,kem_ss:bitstring;
      event(ClientStateEv(ev,kem_ss)) &&
      event(ServerStateEv(ev,kem_ss))
.

query ev:bitstring,kch:ae_key;
      event(ClientStateEvKch(ev,kch)) &&
      event(ServerStateEvKch(ev,kch))
.

query ev:bitstring,kc:ae_key;
      event(ClientStateEvKc(ev,kc)) &&
      event(ServerStateEvKc(ev,kc))
.


(**********************************************************************)
(* EKK Proof of Possession *)
(* should be false (confirms event is reachable) *)
query ekk_pop:bitstring;
      event(Appraised(ekk_pop)).

(**********************************************************************)
(* Binding *)
(*
Goal G1: Binding Evidence to TLS session: Evidence should not be usable in
  other TLS sessions, even if they are between the same endpoints.
  (Not binding to endpoints because multiple sessions of endpoints are possible)
3 levels of binding to TLS session: 
  L1. kem_ss (ek,ciph)
  L2. kch (up to ServerHello)
  L3. kc (up to ServerFinished): may include ID_S in Certificate message
  L1 <= L2 <= L3
Formalization: Same evidence is not accepted by two different TLS sessions.
  TLS session identified by kem_ss. Trace should not contain:
  Client(ev1,kem_ss1); Server(ev1,kem_ss2);
  (* Informal: If they see the same evidence, they should be in the same session *)
Parameters: Evidence instead of dev_state
  ds = ev, kem_ss
  server identity not a part of the query because that is covered by G-C2
Events: 
  ServerStateEv after verifying CFin.
  Rationale: Both endpoints have accepted the connection with the same evidence. 
Result: true
*)
query ev:bitstring,kem_ss1:bitstring,kem_ss2:bitstring,
 pubCSK:pubkey,dev_state:bitstring,Evidence:bitstring,
      cr:random, sr:random, cr':random, sr':random,
      ID:identity,pubLTK:pubkey,pubAEK:pubkey,
      psk:preSharedKey, ct:kem_ct,
      offer:params, mode:params, ID_S:identity,
      kc:ae_key,ks:ae_key,ems:bitstring,rms:bitstring;
      event(ClientStateEv(ev,kem_ss1)) &&
      event(ServerStateEv(ev,kem_ss2)) ==>
      (kem_ss1 = kem_ss2)
.

(*
Goal G2: Binding to client_write_key (kch) derived from handshake traffic secret (htsc) 
Rationale: It has ctx_SH in addition to kem_ss
Result: true
*)
query ev:bitstring,kch1:ae_key,kch2:ae_key;
      event(ClientStateEvKch(ev,kch1)) &&
      event(ServerStateEvKch(ev,kch2)) ==>
      (kch1 = kch2)
.

(* 
Goal G3: w.r.t. client_write_key (kc) for application data derived from client_application_traffic_secret_0 (atsc) 
Rationale: It has transcript hash up to ctx_SF (vs. ctx_SH in above property).
Result: true
*)
query ev:bitstring,kc1:ae_key,kc2:ae_key;
      event(ClientStateEvKc(ev,kc1)) &&
      event(ServerStateEvKc(ev,kc2)) ==>
      (kc1 = kc2)
.


(* With cryptographic assumptions 

(* Goal G3: Session binding for application data write key *)
query ev:bitstring, pop:bitstring, kc1:ae_key, kc2:ae_key, ct:kem_ct,
      cr:random, sr:random, cr':random, sr':random;
      event(ClientStateEvKc2(ev, cr, sr, kc1)) &&
      event(ServerStateEvKc2(ev, cr, sr, kc2)) ==>
      (kc1 = kc2)
      || event(ServerChoosesKEX(cr,sr,MLKEM_13_S(WeakKEM,ct)))
      || event(ServerChoosesHash(cr',sr',WeakHash))
.
*)

(**********************************************************************)
(* Application-Data Agreement — Sanity Checks *)
(**********************************************************************)

(* should be false (confirms event is reachable) *)
query VM_S:identity, pubLTK:pubkey, pubAEK:pubkey, pubCSK:pubkey, pubEKK:pubkey,
      psk:preSharedKey, offer:params, mode:params, kc:ae_key, ks:ae_key,
      ems:bitstring, rms:bitstring, cr:random, sr:random,
      dev_state:bitstring, app_data:bitstring;
      event(ClientReceivesAppData(VM_S, pubCSK, pubAEK, pubEKK, psk, offer, mode, kc, ks, ems, rms, cr, sr, pubLTK, dev_state, app_data)).

(* should be false (confirms event is reachable) *)
query VM_S:identity, pubLTK:pubkey, pubAEK:pubkey, pubCSK:pubkey, pubEKK:pubkey,
      psk:preSharedKey, offer:params, mode:params, kc:ae_key, ks:ae_key,
      ems:bitstring, rms:bitstring, cr:random, sr:random,
      dev_state:bitstring, app_data:bitstring;
      event(ServerSendsAppData(VM_S, pubCSK, pubAEK, pubEKK, psk, offer, mode, kc, ks, ems, rms, cr, sr, pubLTK, dev_state, app_data)).

(* should be false (confirms both events are reachable) *)
query VM_S:identity, pubLTK:pubkey, pubAEK:pubkey, pubCSK:pubkey, pubEKK:pubkey,
      psk:preSharedKey, offer:params, mode:params, kc:ae_key, ks:ae_key,
      ems:bitstring, rms:bitstring, cr:random, sr:random,
      dev_state:bitstring, app_data:bitstring;
      event(ClientReceivesAppData(VM_S, pubCSK, pubAEK, pubEKK, psk, offer, mode, kc, ks, ems, rms, cr, sr, pubLTK, dev_state, app_data)) &&
      event(ServerSendsAppData(VM_S, pubCSK, pubAEK, pubEKK, psk, offer, mode, kc, ks, ems, rms, cr, sr, pubLTK, dev_state, app_data)).

query VM_S:identity, pubLTK:pubkey, pubAEK:pubkey, pubCSK:pubkey, pubEKK:pubkey,
      psk:preSharedKey, offer:params, mode:params, kc:ae_key, ks:ae_key,
      ems:bitstring, rms:bitstring, cr:random, sr:random,
      dev_state:bitstring, app_data:bitstring;
      inj-event(ClientReceivesAppData(VM_S, pubCSK, pubAEK, pubEKK, psk, offer, mode, kc, ks, ems, rms, cr, sr, pubLTK, dev_state, app_data))
      ==> inj-event(ServerSendsAppData(VM_S, pubCSK, pubAEK, pubEKK, psk, offer, mode, kc, ks, ems, rms, cr, sr, pubLTK, dev_state, app_data)).

(* Test Key Leak and Binding *)
query VM_S: identity, pubLTK: pubkey, pubAEK: pubkey, pubCSK: pubkey, pubEKK:pubkey, psk: preSharedKey,
      offer: params, mode: params, kc: ae_key, ks: ae_key, ems: bitstring, rms: bitstring, ct:kem_ct,
      cr:random, sr:random, cr':random, sr':random, dev_state: bitstring, app_data: bitstring;
      inj-event(ClientReceivesAppData(VM_S, pubCSK, pubAEK, pubEKK, psk, offer, mode, kc, ks, ems, rms, cr, sr, pubLTK, dev_state, app_data))
      ==> inj-event(ServerSendsAppData(VM_S, pubCSK, pubAEK, pubEKK, psk, offer, mode, kc, ks, ems, rms, cr, sr, pubLTK, dev_state, app_data))
      || event(ServerChoosesKEX(cr,sr,MLKEM_13_S(WeakKEM,ct)))
      || event(LeakedEKK(pubEKK))
. 


query VM_S: identity, pubLTK: pubkey, pubAEK: pubkey, pubCSK: pubkey, pubEKK:pubkey, psk: preSharedKey,
      offer: params, mode: params, kc: ae_key, ks: ae_key, ems: bitstring, rms: bitstring, ct:kem_ct,
      cr:random, sr:random, cr':random, sr':random, dev_state: bitstring, app_data: bitstring;
      inj-event(ClientReceivesAppData(VM_S, pubCSK, pubAEK, pubEKK, psk, offer, mode, kc, ks, ems, rms, cr, sr, pubLTK, dev_state, app_data))
      ==> inj-event(ServerSendsAppData(VM_S, pubCSK, pubAEK, pubEKK, psk, offer, mode, kc, ks, ems, rms, cr, sr, pubLTK, dev_state, app_data))
      || event(ServerChoosesKEX(cr,sr,MLKEM_13_S(WeakKEM,ct)))
      || event(LeakedAEK(pubAEK))    
.


query VM_S: identity, pubLTK: pubkey, pubAEK: pubkey, pubCSK: pubkey, pubEKK:pubkey, psk: preSharedKey,
      offer: params, mode: params, kc: ae_key, ks: ae_key, ems: bitstring, rms: bitstring, ct:kem_ct,
      cr:random, sr:random, cr':random, sr':random, dev_state: bitstring, app_data: bitstring;
      inj-event(ClientReceivesAppData(VM_S, pubCSK, pubAEK, pubEKK, psk, offer, mode, kc, ks, ems, rms, cr, sr, pubLTK, dev_state, app_data))
      ==> inj-event(ServerSendsAppData(VM_S, pubCSK, pubAEK, pubEKK, psk, offer, mode, kc, ks, ems, rms, cr, sr, pubLTK, dev_state, app_data))
      || event(ServerChoosesKEX(cr,sr,MLKEM_13_S(WeakKEM,ct)))
      || event(ServerChoosesHash(cr',sr',WeakHash))
      || event(LeakedCSK(pubCSK))    
.


(********************************************************)
(* Client                                               *)
(********************************************************)
let Client(ID_C:identity, VM_S:identity, pubARK:pubkey, pubLTK:pubkey, cached_AR:bitstring) =
(
  (* Unpack and verify the cached Attestation Result against the RP's Appraisal Policy *)
  let (ar_claims:bitstring, ar_sig:bitstring) = cached_AR in
  let (=VM_S, pubCSK:pubkey, pubAEK:pubkey, pubEKK:pubkey) = ar_claims in
  if verify(pubARK, ar_claims, ar_sig) = true then

  (* Mint the Interactive-Passport challenge against the appraised pubEKK *)
  new ekk_secret: bitstring;
  let ct = EKKEncaps(ekk_secret, pubEKK) in

  (* KEX negotiation — adversary drives KEM parameter set and hash selection *)
  in(io, ioffer:params);
  let nego(=aTLS, MLKEM_13_C(ka,eee), hash_algo, ev_type) = ioffer in

(* --- * )
(* Drop weak cryptographic branches immediately *)
if hash_algo = StrongHash then
if ka = StrongKEM then
( * --- *)

  let (dk:kem_priv, ek:kem_pub) = kem_keygen() in
  let offer = nego(aTLS, MLKEM_13_C(ka,ek), hash_algo, ev_type) in

  new cr:random;  (* ClientHello.random — RFC 9846 sect. 4.2.2 *)
  let ch = CH(cr, offer, ct) in

  (* Standard TLS 1.3 NoPSK Early Secret — RFC 9846 sect. 7.1 *)
  let psk = NoPSK in
  let (es:bitstring, kb:mac_key, kc0:ae_key, ems0:bitstring) = kdf_es(psk, msg2bytes(ch)) in

  event ClientOffersHash(cr, hash_algo);
  event ClientOffersKEX(cr, MLKEM_13_C(ka,ek));
  event ClientOffersEvType(cr, ev_type);

  (****************************)
  (* Send ClientHello — RFC 9846 sect. 4.2.2, carrying the Interactive-Passport
     KEM challenge ciphertext ct alongside the standard offer *)
  out(io, ch);
  (****************************)

  (****************************)
  (* Receive ServerHello — RFC 9846 sect. 4.1.3 *)
  in(io, SH(sr, mode)) [precise];
  (****************************)

  let nego(=aTLS, MLKEM_13_S(=ka,ciph), shash_algo, sev_type) = mode in
  let ctx_SH = (ch, SH(sr,mode)) in  (* sent ClientHello || received ServerHello *)

(* --- * )
(* Drop weak hash downgrade immediately upon receipt *)
if shash_algo = StrongHash then
( * --- *)

  let kem_ss = kem_decap(ka, dk, ciph) in  (* ML-KEM shared secret — RFC 9846 sect. 7.1 *)
  let (hs:bitstring, kch:ae_key, ksh:ae_key, kcm:mac_key, ksm:mac_key) = kdf_hs(es, kem_ss, ctx_SH) in

  (*******************************)
  (* Receive Certificate — RFC 9846 sect. 4.4.2, carrying the Evidence, the
     server's identity, its LTK delegation, and the EKK PoP tag *)
  in(io, CRT(Evidence, =VM_S, ltk_dc, ekk_pop));
  (*******************************)

  (* Session Binding Value — hashes the transcript up to ServerHello *)
  let sbv = ctx_SH in

  (**********************************************)
  (* RELAY TO 3RD-PARTY VERIFIER: send encrypted 
     Evidence and binder over io *)
  out(io, (Evidence, sbv));
  in(io, AttestionResult: bitstring);
  (**********************************************)

  let ev_hash = hash(StrongHash, (Evidence)) in

  (* Unpack and appraise the Verifier's signed AR_token *)
  let (ar_token:bitstring, vsig:bitstring) = AttestionResult in
  let (ear_claims:bitstring, =ev_hash) = ar_token in

  let (claims:bitstring, =sbv) = ear_claims in
  let (=VM_S, =pubCSK, =pubAEK, =pubEKK) = claims in
  if verify(pubARK, ar_token, vsig) = true then

  (* EKK PoP verification — client already knows ekk_secret from its own
     encapsulation; confirms the Server currently holds privEKK bound to
     this connection's transcript *)
  if ekk_pop = hmac(StrongHash, (b2mk(ekk_secret)), sbv) then
  event Appraised(ekk_pop);

  (* RFC 9345 §4 Delegated Credential: LTK delegates TLS signing authority
     to TEE-bound privCSK (ephemeral identity signing key). Validated per RFC 9345 §4.1.3. *)
  if verify(pubLTK, (VM_S, pubCSK), ltk_dc) = true then
  let ctx_CRT = (ctx_SH, CRT(Evidence,VM_S,ltk_dc,ekk_pop)) in  (* ... || received Certificate *)

  (*************************************)
  (* Receive CertificateVerify — RFC 9846 sect. 4.4.3 *)
  in(io, CV(sg));
  (*************************************)

  if verify(pubCSK, hash(shash_algo, ctx_CRT), sg) = true then

  event Accepted(Evidence);
  event AcceptedRdata(sbv);
  event AcceptedWithPubKey(Evidence, pubCSK);

  let ctx_CV = (ctx_CRT, CV(sg)) in  (* ... || received CertificateVerify *)

  (*********************************)
  (* Receive ServerFinished — RFC 9846 sect. 4.4.4 *)
  in(io, FIN(m1));
  (*********************************)

  if m1 = hmac(StrongHash, ksm, ctx_CV) then
  (
    let ctx_SFIN = (ctx_CV, FIN(m1)) in  (* ... || received ServerFinished *)
    let (ms:bitstring, kc:ae_key, ks:ae_key, ems:bitstring) = kdf_ms(hs, ctx_SFIN) in
    let m2 = hmac(StrongHash, kcm, ctx_SFIN) in
    let ctx_CFIN = (ctx_SFIN, FIN(m2)) in  (* ... || sent ClientFinished *)
    let rms = kdf_psk(ms, ctx_CFIN) in

    event ClientFinished(pubCSK,psk,cr,sr,offer,mode,kc,ks,ems,rms);
    event ClientFinishedAliveness(VM_S);
    event ClientFinishedWeakAgr(VM_S,ID_C);
    event ClientFinAgr(VM_S,ID_C,pubLTK,psk,offer,mode,kc,ks,ems,rms);
    event ClientFin1WayAgr(VM_S,pubLTK,psk,offer,mode,kc,ks,ems,rms);
    event ClientFinRecent1WayAgr(VM_S,pubLTK,psk,offer,mode,kc,ks,ems,rms,cr,sr);
    event ClientFinRecentAgr(VM_S,ID_C,pubLTK,psk,offer,mode,kc,ks,ems,rms,cr,sr);
    event ClientFinishedWithID(VM_S,pubLTK,pubAEK,psk,cr,sr,offer,mode,kc,ks,ems,rms);
    event ClientFinishedWithBothPub(pubAEK,psk,pubCSK,cr,sr,offer,mode,kc,ks,ems,rms);
    event ClientFinishedWithAllPubAndID(VM_S,pubLTK,pubAEK,pubCSK,psk,cr,sr,offer,mode,kc,ks,ems);
    event ClientConn(Evidence);
    event ClientComp(VM_S,pubLTK,psk,offer,mode,kc,ks,ems,rms,cr,sr,pubCSK,Evidence);
    event ClientRA2(pubAEK,pubCSK,Evidence);
    event ClientRA3(pubAEK,pubCSK,Evidence,ID_C);
    event ClientID(VM_S,kem_ss);

    event ClientStateEvKc(Evidence, kc);
    event ClientStateEvKch(Evidence, kch);
    event ClientStateEv(Evidence, kem_ss);

    event ClientStateEvKc2(Evidence, cr, sr, kc);
    event ClientStateEvKch2(Evidence, cr, sr, kch);
    event ClientStateEv2(Evidence, cr, sr, kem_ss);

    (*********************************)
    (* Send ClientFinished — RFC 9846 sect. 4.4.4 *)
    out(io, FIN(m2));
    (*********************************)

    (****************************************)
    (*    CLIENT POST-HANDSHAKE APP DATA    *)
    (****************************************)

    in(io, (=cr, app_msg_enc:bitstring));
    let App_type(app_msg_s) = ph_read(app_msg_enc, ae2b(ks)) in

    event C_Test_logSH(app_msg_s, ctx_SH);
    event C_Test_logCRT(app_msg_s, ctx_CRT);
    event C_Test_logCV(app_msg_s, ctx_CV);
    event C_Test_logSFIN(app_msg_s, ctx_SFIN);
    event C_Test_ID(app_msg_s, VM_S);
    event C_Test_pubLTK(app_msg_s, pubLTK);
    event C_Test_pubAEK(app_msg_s, pubAEK);
    event C_Test_psk(app_msg_s, psk);
    event C_Test_offer(app_msg_s, offer);
    event C_Test_mode(app_msg_s, mode);
    event C_Test_kc(app_msg_s, kc);
    event C_Test_ks(app_msg_s, ks);
    event C_Test_ems(app_msg_s, ems);
    event C_Test_rms(app_msg_s, rms);
    event C_Test_cr(app_msg_s, cr);
    event C_Test_sr(app_msg_s, sr);
    event C_Test_dev(app_msg_s, Evidence);

    event ClientReceivesAppData(VM_S,pubCSK,pubAEK,pubEKK,psk,offer,mode,kc,ks,ems,rms,cr,sr,pubLTK,Evidence,app_msg_s)
  )
).

(********************************************************)
(* Remote Verifier Service                              *)
(********************************************************)

let Verifier(privARK:privkey, privOSK:privkey, pubAEK:pubkey) =
(
  (* Ingest the relayed ciphertext and session binding AAD from the Client *)
  in(io, (enc_evidence:bitstring, sbv_in:bitstring));

  (* Decrypt the Evidence; fails silently if AAD does not match sbv_in or key is wrong *)
  let Evidence = hpke_dec(privOSK, enc_evidence, sbv_in) in

  (* Unpack the plaintext Evidence structure *)
  let (hwSignedBytes:bitstring, sig:bitstring, assertions:bitstring) = Evidence in
  let (rdata:bitstring, hwQuote:bitstring) = hwSignedBytes in

  let (ar_claims_in:bitstring, =sbv_in) = assertions in
  let (VM_S:identity, pubCSK:pubkey, pubAEK_in:pubkey, pubEKK:pubkey, =hwQuote) = ar_claims_in in
  let ar_claims = (VM_S, pubCSK, pubAEK_in, pubEKK) in

  if pubAEK_in = pubAEK then
  if hwQuote = dev_statusRef then
  if rdata = hash(StrongHash, assertions) then
  if verify(pubAEK_in, hwSignedBytes, sig) = true then

  (* Mint the AR_token tagged with the hash of the encrypted evidence *)
  let ear_claims = (ar_claims, sbv_in) in
  let token_payload = (ear_claims, hash(StrongHash, (enc_evidence))) in
  let AR_token = (token_payload, sign(privARK, token_payload)) in

  out(io, AR_token)
).

(********************************************************)
(* Server                                               *)
(********************************************************)

let Server(VM_S:identity, pubLTK: pubkey, pubOSK:pubkey, privAEK:privkey, privCSK: privkey, privEKK:privkey, ltk_dc:bitstring) =
(
  (****************************)
  (* Receive ClientHello — RFC 9846 sect. 4.2.2 *)
  in(io, ch:msg);
  (****************************)

  let CH(cr, offer, ct) = ch in
  let nego(=aTLS, MLKEM_13_C(ka,ek), xhash_algo, xev_type) = offer in

(* --- * )
(* Drop weak cryptographic branches immediately *)
if xhash_algo = StrongHash then
if ka = StrongKEM then
( * --- *)

  (* Standard TLS 1.3 NoPSK Early Secret — RFC 9846 sect. 7.1 *)
  let psk = NoPSK in
  let (es:bitstring, kb:mac_key, kc0:ae_key, ems0:bitstring) = kdf_es(psk, msg2bytes(ch)) in

  new sr:random;  (* ServerHello.random — RFC 9846 sect. 4.1.3 *)

  (* adversary drives mode selection; KEM parameter set must match ClientHello *)
  in(io, smode:params);
  let nego(=aTLS, MLKEM_13_S(=ka,eee), hash_algo, ev_type) = smode in

(* --- * )
(* Drop weak cryptographic branches immediately *)
if hash_algo = StrongHash then
( * --- *)

  new ss_kem: bitstring;  (* freshly generated ML-KEM shared secret *)
  let ciph = kem_encap(ka, ek, ss_kem) in
  let mode = nego(aTLS, MLKEM_13_S(ka,ciph), hash_algo, ev_type) in  (* Server selects mode — RFC 9846 sect. 4.1.3 *)

  event ServerChoosesKEX(cr, sr, MLKEM_13_S(ka,ciph));
  event ServerChoosesHash(cr, sr, hash_algo);
  event ServerChoosesATLS(cr, sr, aTLS);
  event ServerChoosesEvType(cr, sr, ev_type);

  (*****************************)
  (* Send ServerHello — RFC 9846 sect. 4.1.3 *)
  out(io, SH(sr, mode));
  (*****************************)

  let ctx_SH = (ch, SH(sr,mode)) in  (* received ClientHello || sent ServerHello *)

  let kem_ss = ss_kem in  (* ML-KEM shared secret bound into ciph via kem_encap above *)
  let (hs:bitstring, kch:ae_key, ksh:ae_key, kcm:mac_key, ksm:mac_key) = kdf_hs(es, kem_ss, ctx_SH) in

  let pubCSK = pk(privCSK) in
  let pubAEK = pk(privAEK) in
  let pubEKK = pk(privEKK) in
  event ServerID(VM_S, kem_ss);

  (* Attestation Credential generation *)
  in(io, hwQuote: bitstring);  (* simulates adverse remote instances *)
  (* let hwQuote = dev_statusRef in *)
  
  let claim_set = (VM_S, pubCSK, pubAEK, pubEKK, hwQuote) in

  (* Decapsulate the Interactive-Passport challenge and derive the PoP tag *)
  let ekk_secret = EKKDecaps(ct, privEKK) in
  let sbv = ctx_SH in  (* Session Binding Value *)
  let ekk_pop = hmac(StrongHash, (b2mk(ekk_secret)), sbv) in

  let assertions = ((claim_set), sbv) in
  let rdata = hash(StrongHash, assertions) in  (* eat_nonce *)

(*** Attesting Environment Boundary ***)
  (* Hardware ONLY signs the rdata and measurements *)
  let hwSignedBytes = (rdata, hwQuote) in
  let hw_signature = sign(privAEK, hwSignedBytes) in
(*** --- ***)

  (* The overarching Evidence message carries the signed hardware quote plus the plaintext assertions *)
  let claims = (hwSignedBytes, hw_signature, assertions) in

  (* Encrypt Evidence for the Verifier using pubOSK, with sbv as AAD *)
  let Evidence = hpke_enc(pubOSK, claims, sbv) in

  event Sent(Evidence);
  event SentWithPubKey(Evidence, pubCSK);
  event SentRdata(sbv);
  event ServerRA2(pubAEK,pubCSK,Evidence);

  (*****************************)
  (* Send Certificate — RFC 9846 sect. 4.4.2, carrying the Evidence, the
     server's identity, its LTK delegation, and the EKK PoP tag *)
  out(io, CRT(Evidence, VM_S, ltk_dc, ekk_pop));
  (*****************************)

  let ctx_CRT = (ctx_SH, CRT(Evidence,VM_S,ltk_dc,ekk_pop)) in  (* ... || sent Certificate *)

  (* CertificateVerify — RFC 9846 sect. 4.4.3;
     privCSK (LTK-delegated) signs Transcript-Hash(Handshake Context, Certificate) *)
  let sg = sign(privCSK, hash(hash_algo, ctx_CRT)) in

  (*****************************)
  (* Send CertificateVerify — RFC 9846 sect. 4.4.3 *)
  out(io, CV(sg));
  (*****************************)

  let ctx_CV = (ctx_CRT, CV(sg)) in  (* ... || sent CertificateVerify *)

  (* ServerFinished — RFC 9846 sect. 4.4.4 *)
  let m1 = hmac(StrongHash, ksm, ctx_CV) in
  let ctx_SFIN = (ctx_CV, FIN(m1)) in  (* ... || sent ServerFinished *)
  let (ms:bitstring, kc:ae_key, ks:ae_key, ems:bitstring) = kdf_ms(hs, ctx_SFIN) in
  let ID_C = NULL_ID in  (* no client auth *)

  event PreServerFinished(pubCSK,psk,cr,sr,offer,mode,kc,ks,ems);
  event PreServerFinishedAliveness(VM_S);
  event PreServerFinishedWeakAgr(VM_S,ID_C);
  event PreServerFin1WayAgr(VM_S,pubLTK,psk,offer,mode,kc,ks,ems);
  event PreServerFinRecent1WayAgr(VM_S,pubLTK,psk,offer,mode,kc,ks,ems,cr,sr);
  event PreServerFinAgr(VM_S,ID_C,pubLTK,psk,offer,mode,kc,ks,ems);
  event PreServerFinRecentAgr(VM_S,ID_C,pubLTK,psk,offer,mode,kc,ks,ems,cr,sr);
  event PreServerFinishedWithID(VM_S,pubLTK,pubAEK,psk,cr,sr,offer,mode,kc,ks,ems);
  event PreServerFinishedWithBothPub(pubAEK,psk,pubCSK,cr,sr,offer,mode,kc,ks,ems);
  event PreServerFinishedWithAllPubAndID(VM_S,pubLTK,pubAEK,pubCSK,psk,cr,sr,offer,mode,kc,ks,ems);
  event PreServerComp(VM_S,pubLTK,psk,offer,mode,kc,ks,ems,cr,sr,pubCSK,Evidence);

  (*******************************)
  (* Send ServerFinished — RFC 9846 sect. 4.4.4 *)
  out(io, FIN(m1));
  (*******************************)

  (**********************************)
  (* Receive ClientFinished — RFC 9846 sect. 4.4.4 *)
  in(io, FIN(m2));
  (**********************************)

  if m2 = hmac(StrongHash, kcm, ctx_SFIN) then
    let ctx_CFIN = (ctx_SFIN, FIN(m2)) in  (* ... || received ClientFinished *)
    let rms = kdf_psk(ms, ctx_CFIN) in

    event ServerStateEvKc(Evidence, kc);
    event ServerStateEvKch(Evidence, kch);
    event ServerStateEv(Evidence, kem_ss);

    event ServerStateEvKc2(Evidence, cr, sr, kc);
    event ServerStateEvKch2(Evidence, cr, sr, kch);
    event ServerStateEv2(Evidence, cr, sr, kem_ss);

    event ServerFinished(cr,sr,psk,pubLTK,offer,mode,kc,ks,ems,rms);
    event ServerComp(VM_S,pubLTK,psk,offer,mode,kc,ks,ems,cr,sr,pubCSK,Evidence);

    (****************************************)
    (*    SERVER POST-HANDSHAKE APP DATA    *)
    (****************************************)

    new app_msg: bitstring;

    event S_Test_logSH(app_msg, ctx_SH);
    event S_Test_logCRT(app_msg, ctx_CRT);
    event S_Test_logCV(app_msg, ctx_CV);
    event S_Test_logSFIN(app_msg, ctx_SFIN);
    event S_Test_ID(app_msg, VM_S);
    event S_Test_pubLTK(app_msg, pubLTK);
    event S_Test_pubAEK(app_msg, pubAEK);
    event S_Test_psk(app_msg, psk);
    event S_Test_offer(app_msg, offer);
    event S_Test_mode(app_msg, mode);
    event S_Test_kc(app_msg, kc);
    event S_Test_ks(app_msg, ks);
    event S_Test_ems(app_msg, ems);
    event S_Test_rms(app_msg, rms);
    event S_Test_cr(app_msg, cr);
    event S_Test_sr(app_msg, sr);
    event S_Test_dev(app_msg, Evidence);

    event ServerSendsAppData(VM_S,pubCSK,pubAEK,pubEKK,psk,offer,mode,kc,ks,ems,rms,cr,sr,pubLTK,Evidence,app_msg);
    out(io, (cr, ph_msg(App_type(app_msg), ae2b(ks))))
).

(* --------------------------------------------------------------
Verification summary: [Background-Check conveyance Model]

Query not (event(ClientStateEv(ev,kem_ss_2)) && event(ServerStateEv(ev,kem_ss_2))) is false.

Query not (event(ClientStateEvKch(ev,kch_4)) && event(ServerStateEvKch(ev,kch_4))) is false.

Query not (event(ClientStateEvKc(ev,kc_4)) && event(ServerStateEvKc(ev,kc_4))) is false.

Query not event(Appraised(ekk_pop_2)) is false.

Query event(ClientStateEv(ev,kem_ss1)) && event(ServerStateEv(ev,kem_ss2)) ==> kem_ss1 = kem_ss2 is true.

Query event(ClientStateEvKch(ev,kch1)) && event(ServerStateEvKch(ev,kch2)) ==> kch1 = kch2 is true.

Query event(ClientStateEvKc(ev,kc1)) && event(ServerStateEvKc(ev,kc2)) ==> kc1 = kc2 is true.

Query inj-event(ClientReceivesAppData(VM_S_4,pubCSK_8,pubAEK_8,psk_2,offer_2,mode_2,kc_4,ks_4,ems_4,rms_2,cr_2,sr_2,pubLTK_6,dev_state,app_data)) ==> inj-event(ServerSendsAppData(VM_S_4,pubCSK_8,pubAEK_8,psk_2,offer_2,mode_2,kc_4,ks_4,ems_4,rms_2,cr_2,sr_2,pubLTK_6,dev_state,app_data)) || event(ServerChoosesKEX(cr_2,sr_2,MLKEM_13_S(WeakKEM,ct_2))) || event(LeakedEKK(pubEKK_7)) is true.

Query inj-event(ClientReceivesAppData(VM_S_4,pubCSK_8,pubAEK_8,psk_2,offer_2,mode_2,kc_4,ks_4,ems_4,rms_2,cr_2,sr_2,pubLTK_6,dev_state,app_data)) ==> inj-event(ServerSendsAppData(VM_S_4,pubCSK_8,pubAEK_8,psk_2,offer_2,mode_2,kc_4,ks_4,ems_4,rms_2,cr_2,sr_2,pubLTK_6,dev_state,app_data)) || event(ServerChoosesKEX(cr_2,sr_2,MLKEM_13_S(WeakKEM,ct_2))) || event(LeakedAEK(pubAEK_8)) is true.

Query inj-event(ClientReceivesAppData(VM_S_4,pubCSK_8,pubAEK_8,psk_2,offer_2,mode_2,kc_4,ks_4,ems_4,rms_2,cr_2,sr_2,pubLTK_6,dev_state,app_data)) ==> inj-event(ServerSendsAppData(VM_S_4,pubCSK_8,pubAEK_8,psk_2,offer_2,mode_2,kc_4,ks_4,ems_4,rms_2,cr_2,sr_2,pubLTK_6,dev_state,app_data)) || event(ServerChoosesKEX(cr_2,sr_2,MLKEM_13_S(WeakKEM,ct_2))) || event(ServerChoosesHash(cr',sr',WeakHash)) || event(LeakedCSK(pubCSK_8)) is true.

-------------------------------------------------------------- *)
